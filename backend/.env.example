# Copy to .env and adjust as needed. All values are optional.

# Database (defaults to a local SQLite file if unset).
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/ethara

# Comma-separated allowed CORS origins (defaults to "*").
# CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Optional: enable LLM-polished AI answers. Without this the assistant uses the
# built-in deterministic rule-based engine (fully functional, no key needed).
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
